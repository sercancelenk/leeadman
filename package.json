{
  "name": "leeadman",
  "version": "0.2.0",
  "private": true,
  "description": "Local leadership workspace — people, tasks, notes, goals, reminders",
  "main": "electron/main.cjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/sercancelenk/leeadman.git"
  },
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build:web": "vite build",
    "build": "vite build && electron-builder",
    "preview": "vite preview",
    "build:release": "vite build && electron-builder --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.leeadman.app",
    "productName": "Leeadman",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "YOUR_GITHUB_USERNAME",
        "repo": "leeadman",
        "draft": false
      }
    ],
    "mac": {
      "category": "public.app-category.productivity"
    }
  }
}
